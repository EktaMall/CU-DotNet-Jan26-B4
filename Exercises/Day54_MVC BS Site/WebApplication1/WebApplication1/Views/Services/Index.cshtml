@{
    ViewData["Title"] = "Services";
}

<h2 class="mb-4">Our Services</h2>

<div class="row">

    <div class="col-md-6">
        <div class="card shadow">
            <div class="card-body text-center">

                <h4 class="card-title">Consulting</h4>
                <p class="card-text">
                    Expert IT consulting to help businesses plan and implement technology solutions.
                </p>

                <a asp-controller="Services"
                   asp-action="Consulting"
                   class="btn btn-primary">
                    View Consulting
                </a>

            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card shadow">
            <div class="card-body text-center">

                <h4 class="card-title">Training</h4>
                <p class="card-text">
                    Professional training programs for developers and IT teams in various domains.
                </p>

                <a asp-controller="Services"
                   asp-action="Training"
                   class="btn btn-success">
                    View Training
                </a>

            </div>
        </div>
    </div>

</div>