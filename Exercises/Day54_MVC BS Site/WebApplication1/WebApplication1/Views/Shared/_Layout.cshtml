<!DOCTYPE html>
<html>
<head>
    <title>Company Portal</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">

            <a class="navbar-brand d-flex align-items-center"
               asp-controller="Home"
               asp-action="Index">

                <img src="~/icon/CU Logo.jpeg"
                     width="40"
                     height="60"
                     class="me-2">

                CompanyPortal
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#menu">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="menu">

                <ul class="navbar-nav">

                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown">Home</a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" asp-controller="Home" asp-action="Index">Home</a></li>
                            <li><a class="dropdown-item" asp-controller="Home" asp-action="About">About</a></li>
                        </ul>
                    </li>

                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown">Services</a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" asp-controller="Services" asp-action="Index">All Services</a></li>
                            <li><a class="dropdown-item" asp-controller="Services" asp-action="Consulting">Consulting</a></li>
                            <li><a class="dropdown-item" asp-controller="Services" asp-action="Training">Training</a></li>
                        </ul>
                    </li>

                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown">Products</a>
                        <ul class="dropdown-menu">
                            <li><a class="dropdown-item" asp-controller="Products" asp-action="Index">All products</a></li>
                            <li><a class="dropdown-item" asp-controller="Products" asp-action="Software">Software</a></li>
                            <li><a class="dropdown-item" asp-controller="Products" asp-action="Tools">Tools</a></li>
                        </ul>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Contact" asp-action="Index">Contact</a>
                    </li>

                </ul>
            </div>
        </div>
    </nav>

    <div class="container mt-4">
        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>