@page
@model RegisterModel
@{
    ViewData["Title"] = "Register";
}

<style>
    body {
        background: linear-gradient(135deg, #0d6efd, #6610f2);
    }

    .register-card {
        backdrop-filter: blur(15px);
        border-radius: 20px;
        overflow: hidden;
        transition: 0.3s ease;
    }

        .register-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 35px rgba(0,0,0,0.3);
        }

    .left-panel {
        background: linear-gradient(135deg, #212529, #343a40);
    }

    .btn-custom {
        transition: 0.3s ease;
    }

        .btn-custom:hover {
            transform: scale(1.05);
        }

    .form-control:focus {
        box-shadow: 0 0 8px rgba(13,110,253,0.5);
        border-color: #0d6efd;
    }
</style>

<div class="container d-flex align-items-center justify-content-center vh-100">
    <div class="row register-card shadow-lg" style="max-width: 900px; width:100%;">

        <!-- LEFT PANEL -->
        <div class="col-md-6 left-panel text-white d-flex flex-column justify-content-center align-items-center p-5">
            <h1 class="fw-bold">Car Management System</h1>
            <p class="text-center mt-3">
                Create your account and start managing your cars easily.
            </p>
        </div>

        <!-- RIGHT PANEL -->
        <div class="col-md-6 bg-white p-5">
            <h3 class="mb-4 text-center fw-bold">Create Account </h3>

            <form asp-route-returnUrl="@Model.ReturnUrl" method="post">

                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <!-- Email -->
                <div class="form-floating mb-3">
                    <input asp-for="Input.Email" class="form-control" placeholder="name@example.com" />
                    <label>Email address</label>
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <!-- Password -->
                <div class="form-floating mb-3">
                    <input asp-for="Input.Password" type="password" class="form-control" placeholder="Password" />
                    <label>Password</label>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>

                <!-- Confirm Password -->
                <div class="form-floating mb-3">
                    <input asp-for="Input.ConfirmPassword" type="password" class="form-control" placeholder="Confirm Password" />
                    <label>Confirm Password</label>
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
                </div>

                <!-- Button -->
                <button type="submit" class="btn btn-success w-100 py-2 btn-custom">
                    📝 Register
                </button>

                <!-- Links -->
                <div class="text-center mt-3">
                    <span>Already have an account?</span><br />
                    <a asp-page="./Login">Login here</a>
                </div>

            </form>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}