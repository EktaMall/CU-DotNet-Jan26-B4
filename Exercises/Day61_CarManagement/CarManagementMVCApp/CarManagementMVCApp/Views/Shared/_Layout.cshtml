<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - CarHub</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body style="background: linear-gradient(135deg, #0d6efd, #6610f2); min-height:100vh;">

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow">
        <div class="container">

            <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                CarHub
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">

                <ul class="navbar-nav me-auto">

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                    </li>

                    @if (User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Cars" asp-action="Index">Cars</a>
                        </li>
                    }

                </ul>

                <ul class="navbar-nav">

                    @if (User.Identity.IsAuthenticated)
                    {
                        
                        <ul class="navbar-nav ms-auto align-items-center">

                            <!-- 👤 Username -->
                            <li class="nav-item me-3 text-white">
                                👤 @User.Identity.Name
                            </li>

                            <!-- 🔐 Admin Only -->
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link nav-premium" asp-controller="Admin" asp-action="Users">
                                        👥 Users
                                    </a>
                                </li>
                            }

                            <!-- 🚪 Logout -->
                            <li class="nav-item ms-2">
                                <form asp-area="Identity" asp-page="/Account/Logout" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-outline-light btn-sm">
                                        Logout
                                    </button>
                                </form>
                            </li>

                        </ul>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="btn btn-outline-light btn-sm me-2"
                               asp-area="Identity" asp-page="/Account/Login">
                                Login
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="btn btn-light btn-sm"
                               asp-area="Identity" asp-page="/Account/Register">
                                Register
                            </a>
                        </li>
                    }

                </ul>

            </div>
        </div>
    </nav>

    <div class="container mt-4">
        <div class="bg-white p-4 rounded-4 shadow">
            @RenderBody()
        </div>
    </div>

    <footer class="text-center text-white mt-4 mb-2">
        <small>
            © 2026 | Car Management System |
        </small>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>