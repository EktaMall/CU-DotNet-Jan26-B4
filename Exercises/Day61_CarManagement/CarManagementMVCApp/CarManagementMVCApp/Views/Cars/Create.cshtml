@model CarManagementMVCApp.Models.Car

@{
    ViewData["Title"] = "Add Car";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-primary text-white text-center rounded-top-4">
                    <h3>Add New Car</h3>
                </div>

                <div class="card-body p-4">

                    <form asp-action="Create">

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <!-- Brand -->
                        <div class="form-floating mb-3">
                            <input asp-for="Brand" class="form-control" placeholder="Brand" />
                            <label>Brand</label>
                            <span asp-validation-for="Brand" class="text-danger"></span>
                        </div>

                        <!-- Model -->
                        <div class="form-floating mb-3">
                            <input asp-for="Model" class="form-control" placeholder="Model" />
                            <label>Model</label>
                            <span asp-validation-for="Model" class="text-danger"></span>
                        </div>

                        <!-- Year -->
                        <div class="form-floating mb-3">
                            <input asp-for="Year" class="form-control" placeholder="Year" />
                            <label>Year</label>
                            <span asp-validation-for="Year" class="text-danger"></span>
                        </div>

                        <!-- Price -->
                        <div class="form-floating mb-3">
                            <input asp-for="Price" class="form-control" placeholder="Price" />
                            <label>Price</label>
                            <span asp-validation-for="Price" class="text-danger"></span>
                        </div>

                        <!-- Buttons -->
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success">
                                Create Car
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                Back to List
                            </a>
                        </div>

                    </form>

                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}