@model CarManagementMVCApp.Models.Car

@{
    ViewData["Title"] = "Car Details";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="card shadow-lg border-0 rounded-4">

                <!-- Header -->
                <div class="card-header bg-info text-white text-center rounded-top-4">
                    <h3> Car Details!</h3>
                </div>

                <!-- Body -->
                <div class="card-body p-4">

                    <div class="mb-3">
                        <label class="fw-bold">Brand</label>
                        <p class="form-control">@Model.Brand</p>
                    </div>

                    <div class="mb-3">
                        <label class="fw-bold">Model</label>
                        <p class="form-control">@Model.Model</p>
                    </div>

                    <div class="mb-3">
                        <label class="fw-bold">Year</label>
                        <p class="form-control">@Model.Year</p>
                    </div>

                    <div class="mb-3">
                        <label class="fw-bold">Price</label>
                        <p class="form-control">₹ @Model.Price</p>
                    </div>

                    <!-- Buttons -->
                    <div class="d-grid gap-2">

                        <!-- ✅ Only Admin can see Edit -->
                        @if (User.IsInRole("Admin"))
                        {
                            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">
                                 Edit
                            </a>
                        }

                        <a asp-action="Index" class="btn btn-outline-secondary">
                             Back to List
                        </a>

                    </div>

                </div>

            </div>

        </div>
    </div>
</div>