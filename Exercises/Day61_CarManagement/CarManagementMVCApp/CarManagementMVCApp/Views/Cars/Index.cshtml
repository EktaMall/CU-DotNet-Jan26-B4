<style>
    body {
        background: linear-gradient(135deg, #1e3c72, #2a5298);
    }

    .car-container {
        background: #f1f3f5; /* light grey */
        border-radius: 20px;
        padding: 30px;
    }

    .car-card {
        border-radius: 18px;
        transition: 0.3s ease;
        background: #ffffff;
    }

    .car-card:hover {
        transform: translateY(-8px) scale(1.02);
        box-shadow: 0 20px 40px rgba(0,0,0,0.2);
    }

    .price {
        font-weight: bold;
        color: #198754;
        font-size: 18px;
    }

    .btn-custom {
        transition: 0.3s ease;
    }

    .btn-custom:hover {
        transform: scale(1.05);
    }

    .section-title {
        font-weight: 700;
        color: #333;
    }
</style>

<div class="container mt-5">

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4 text-white">
        <h2 class="fw-bold">CarHub</h2>

        @if (User.IsInRole("Admin") || User.IsInRole("Customer"))
        {
            <a asp-action="Create" class="btn btn-success btn-custom">
                ➕ Add Car
            </a>
        }
    </div>

    <!-- Card Container -->
    <div class="car-container shadow">

        <h4 class="section-title mb-4">All Cars</h4>

        <div class="row">

            @foreach (var item in Model)
            {
                <div class="col-md-4 mb-4">

                    <div class="card car-card shadow-sm border-0 p-3">

                        <div class="card-body text-center">

                            <h5 class="fw-bold">@item.Brand @item.Model</h5>

                            <p class="text-muted mb-1">Year: @item.Year</p>

                            <p class="price">₹ @item.Price</p>

                            <!-- Buttons -->
                            <div class="d-flex justify-content-center gap-2 mt-3">

                                <a asp-action="Details" asp-route-id="@item.Id"
                                   class="btn btn-info btn-sm">
                                    View
                                </a>

                                @if (User.IsInRole("Admin"))
                                {
                                    <a asp-action="Edit" asp-route-id="@item.Id"
                                       class="btn btn-warning btn-sm">
                                        Edit
                                    </a>

                                    <a asp-action="Delete" asp-route-id="@item.Id"
                                       class="btn btn-danger btn-sm">
                                        Delete
                                    </a>
                                }

                            </div>

                        </div>

                    </div>

                </div>
            }

        </div>

    </div>
</div>