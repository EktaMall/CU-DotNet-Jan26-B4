@{
    ViewData["Title"] = "Home";
}

<style>
    .hero {
        padding: 80px 20px;
        text-align: center;
    }

    .hero-title {
        font-size: 3rem;
        font-weight: bold;
        color: #0d6efd;
    }

    .hero-subtitle {
        font-size: 1.2rem;
        color: #555;
    }

    .btn-custom {
        transition: 0.3s ease;
    }

        .btn-custom:hover {
            transform: scale(1.05);
        }

    .desc-card {
        transition: 0.3s ease;
        border-radius: 15px;
    }

        .desc-card:hover {
            transform: translateY(-8px);
            box-shadow: 0px 10px 25px rgba(0,0,0,0.2);
        }
</style>

<div class="hero">
    <h1 class="hero-title">Car Management System</h1>
    <p class="hero-subtitle mt-3">
        A simple and secure platform to manage car records efficiently.
    </p>

    @if (!User.Identity.IsAuthenticated)
    {
        <a asp-area="Identity" asp-page="/Account/Login"
           class="btn btn-primary btn-lg mt-4 me-2 btn-custom">
            🔐 Login
        </a>

        <a asp-area="Identity" asp-page="/Account/Register"
           class="btn btn-outline-primary btn-lg mt-4 btn-custom">
            📝 Register
        </a>
    }
    else
    {
        <a asp-controller="Cars" asp-action="Index"
           class="btn btn-success btn-lg mt-4 btn-custom">
             Go to Dashboard
        </a>
    }
</div>

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">

            <div class="card desc-card shadow border-0 p-4 text-center">
                <h4 class="fw-bold mb-3">About the System</h4>
                <p class="text-muted">
                    This Car Management System allows users to efficiently manage car data
                    through a secure and structured interface. It provides smooth navigation,
                    easy data handling and a user-friendly experience.
                </p>
            </div>

        </div>
    </div>
</div>