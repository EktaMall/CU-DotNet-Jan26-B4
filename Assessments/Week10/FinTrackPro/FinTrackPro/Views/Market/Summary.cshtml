<h2>Market Summary</h2>

<div class="alert alert-info">
    Market Status : @ViewBag.Status
</div>

<div class="card" style="width:18rem">
    <div class="card-body">

        <h5 class="card-title">
            Top Gainer : @ViewData["TopGainer"]
        </h5>

        <p>
            Volume : @ViewData["Volume"]
        </p>

    </div>
</div>