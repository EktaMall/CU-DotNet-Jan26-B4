<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>FinTrack Pro</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

</head>

<body>

    @if (TempData["Success"] != null)
    {
        <div class="toast-container position-fixed top-0 end-0 p-3">
            <div class="toast show bg-success text-white">
                <div class="toast-body">
                    @TempData["Success"]
                </div>
            </div>
        </div>
    }

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        
        <div class="container">

            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                FinTrack Pro
            </a>

            <div class="navbar-nav">

                <a class="nav-link" asp-controller="Account" asp-action="Index">
                    Accounts
                </a>

                <a class="nav-link" asp-controller="Transaction" asp-action="Index">
                    Transactions
                </a>

                <a class="nav-link" asp-controller="Portfolio" asp-action="Index">
                    Portfolio
                </a>

                <a class="nav-link" asp-controller="Market" asp-action="Summary">
                    Market
                </a>

            </div>

        </div>
    </nav>


    <div class="container mt-4">
        @RenderBody()
    </div>


    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>