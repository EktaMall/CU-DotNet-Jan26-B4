<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TravelDestinationFrontend</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<style>
    body {
        margin: 0;
        background: linear-gradient(135deg, #0f172a, #1e293b, #334155);
        color: var(--text-main);
        font-family: 'Segoe UI', sans-serif;
    }

    /* HEADER */
    .header {
        height: 60px;
        background: rgba(15, 23, 42, 0.85);
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 25px;
        border-bottom: 1px solid rgba(255,255,255,0.08);
        backdrop-filter: blur(10px);
    }

    .logo {
        font-weight: 700;
        font-size: 1.2rem;
    }

    .nav-links a {
        margin-left: 15px;
        color: #cbd5f5;
        text-decoration: none;
        padding: 6px 12px;
        border-radius: 8px;
        transition: 0.2s;
    }

        .nav-links a:hover {
            background: rgba(255,255,255,0.08);
        }

    /* HERO */
    .hero {
        padding: 30px;
        background: linear-gradient(135deg, rgba(15,23,42,0.9), rgba(30,41,59,0.9));
        border-bottom: 1px solid rgba(255,255,255,0.08);
    }

        .hero h2 {
            margin: 0;
            font-weight: 600;
        }

    /* MAIN */
    .main-container {
        display: grid;
        grid-template-columns: 1fr 280px;
        gap: 20px;
        padding: 25px;
        position: relative;
    }

        /* Glow effect */
        .main-container::before {
            content: "";
            position: absolute;
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, rgba(255,165,0,0.15), transparent);
            top: -100px;
            left: -100px;
            z-index: 0;
        }

    /* CONTENT */
    .content-box {
        background: rgba(255, 255, 255, 0.05);
        border-radius: 15px;
        padding: 20px;
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255,255,255,0.08);
        box-shadow: 0 10px 30px rgba(0,0,0,0.3);
        position: relative;
        z-index: 1;
    }

    /* SIDE PANEL */
    .side-panel {
        background: rgba(255, 255, 255, 0.04);
        border-radius: 15px;
        padding: 20px;
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255,255,255,0.08);
        position: relative;
        z-index: 1;
    }

        .side-panel h5 {
            margin-bottom: 15px;
        }

        .side-panel a {
            display: block;
            color: #cbd5f5;
            text-decoration: none;
            margin-bottom: 10px;
            padding: 8px;
            border-radius: 8px;
            transition: 0.2s;
        }

            .side-panel a:hover {
                background: rgba(255,255,255,0.08);
                transform: translateX(3px);
            }

    /* FOOTER */
    footer {
        text-align: center;
        padding: 15px;
        border-top: 1px solid rgba(255,255,255,0.08);
        font-size: 0.9rem;
        background: rgba(15, 23, 42, 0.6);
        backdrop-filter: blur(8px);
    }

    /* MOBILE */
    @@media (max-width: 900px) {
        .main-container {
            grid-template-columns: 1fr;
        }

        .side-panel {
            order: -1;
        }

        .nav-links {
            display: none;
        }
    }
</style>

<body>

    <!-- HEADER -->
    <div class="header">
        <div class="logo">✈️ Travel UI</div>
        <div class="nav-links">
            <a asp-controller="Home" asp-action="Index">Home</a>
            <a asp-controller="Travel" asp-action="Index">Travel</a>
            <a asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </div>

    <!-- HERO -->
    <div class="hero">
        <h2>@ViewData["Title"]</h2>
    </div>

    <!-- MAIN -->
    <div class="main-container">

        <!-- CONTENT -->
        <div class="content-box">
            @RenderBody()
        </div>

        <!-- SIDE PANEL -->
        <div class="side-panel">
            <h5>Quick Access</h5>
            <a asp-controller="Home" asp-action="Index">🏠 Home</a>
            <a asp-controller="Travel" asp-action="Index">🌍 Explore</a>
            <a asp-controller="Home" asp-action="Privacy">🔒 Privacy</a>
        </div>

    </div>

    <!-- FOOTER -->
    <footer>
        &copy; 2026 - TravelDestinationFrontend |
        <a asp-controller="Home" asp-action="Privacy">Privacy</a>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>